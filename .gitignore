# =============================================================================
# Hermes Agent — ~/.hermes/ dotfile gitignore
# =============================================================================
# 策略：只追踪自定义配置和用户创作的内容。
#       不追踪：运行时状态、缓存、二进制、敏感凭证、可从代码恢复的文件。
# =============================================================================

# ── 代码本体（自带 Git 仓库，hermes update 管理） ─────────────────────────
hermes-agent/

# ── 敏感凭证（绝不能进版本控制） ──────────────────────────────────────────
.env
auth.json
auth.lock

# ── SQLite 数据库（二进制 + WAL，频繁变动） ───────────────────────────────
state.db
state.db-shm
state.db-wal
kanban.db
kanban.db-shm
kanban.db-wal

# ── 会话数据（频繁写入，体积大，非配置） ─────────────────────────────────
sessions/
webui/sessions/
webui/_turn_journal/

# ── 日志 ─────────────────────────────────────────────────────────────────
logs/
webui.log

# ── 运行时状态 / 锁文件 / PID ────────────────────────────────────────────
webui.pid
webui.ctl.env
.clean_shutdown
cron/.tick.lock
cron/output/
.update_check

# ── 缓存 ────────────────────────────────────────────────────────────────
cache/
audio_cache/
image_cache/
webui/models_cache.json
sandboxes/

# ── Gateway 运行时状态 ───────────────────────────────────────────────────
gateway_state.json
channel_directory.json
discord_threads.json
gateway/

# ── 二进制 ──────────────────────────────────────────────────────────────
bin/

# ── Skills（全部从 hermes-agent 内置代码复制而来，可随时恢复） ─────────────
# 如果未来你创建了自建 skill，想单独追踪，用 git add -f 强制添加
skills/

# ── WebUI 运行时数据 ─────────────────────────────────────────────────────
webui/last_workspace.txt
