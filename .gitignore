# =============================================================================
# Hermes Agent — ~/.hermes/ dotfile gitignore
# =============================================================================
# 策略：只追踪自定义配置和用户创作的内容。
#       不追踪：运行时状态、缓存、二进制、敏感凭证、可从代码恢复的文件。
# =============================================================================

# ── 代码本体（自带 Git 仓库，hermes update 管理） ─────────────────────────────
hermes-agent/
hermes-webui/
plugins/

# ── 敏感凭证（绝不能进版本控制） ──────────────────────────────────────────────
.env
auth.json

# ── 锁文件 / PID（运行时进程状态） ────────────────────────────────────────────
*.lock
*.pid
.clean_shutdown
Processes.json

# ── SQLite 数据库（二进制 + WAL，频繁变动） ───────────────────────────────────
state.db
state.db-shm
state.db-wal
kanban.db
kanban.db-shm
kanban.db-wal

# ── 会话数据（频繁写入，体积大，非配置） ─────────────────────────────────────
sessions/
sessions.db

# ── 日志 ─────────────────────────────────────────────────────────────────────
logs/

# ── 运行时状态 ──────────────────────────────────────────────────────────────
cron/output/
.update_check
state-snapshots/

# ── 缓存 ────────────────────────────────────────────────────────────────────
cache/
audio_cache/
image_cache/
sandboxes/
*cache.yaml
*cache.json
*snapshot.json

# ── Gateway 运行时状态 ───────────────────────────────────────────────────────
gateway_state.json
channel_directory.json
discord_threads.json
gateway/
gateway.*

# ── WebUI（运行时数据 + 会话 + 控制文件） ─────────────────────────────────────
webui/
webui.*

# ── 二进制 ──────────────────────────────────────────────────────────────────
bin/

# =============================================================================
# Skills ─ 精细化追踪策略
# =============================================================================
# 系统内置 Skill（.bundled_manifest 清单内）→ 不追踪，hermes update 可恢复
# 插件可重装 Skill（bb-browser / doko*）     → 不追踪，npm install -g 可恢复
# 用户自建 Skill（skills/custom/ 整目录）    → 自动纳入 Git 管理
# =============================================================================

# ── Skills 元数据 ────────────────────────────────────────────────────────────
skills/.hub/
skills/.bundled_manifest
skills/.usage.json
skills/.usage.json.lock
skills/.curator_state

# ── 纯内置目录（整目录忽略） ──────────────────────────────────────────────────
skills/apple/
skills/autonomous-ai-agents/
skills/data-science/
# devops/ — 全部内置（hermes-weekly-cleanup 已迁 custom/）
skills/devops/
skills/dogfood/
skills/email/
skills/gaming/
skills/github/
skills/mcp/
skills/media/
skills/mlops/
skills/note-taking/
# productivity/ — 全部内置（tool-selection-strategy 已迁 custom/）
skills/productivity/
skills/red-teaming/
skills/research/
skills/smart-home/
skills/social-media/
skills/software-development/
skills/yuanbao/

# ── 空/废弃分类目录 ──────────────────────────────────────────────────────────
skills/diagramming/
skills/domain/
skills/gifs/
skills/inference-sh/

# ── 第三方可重装 Skill ────────────────────────────────────────────────────────
# bb-browser — npm install -g bb-browser 可恢复
skills/bb-browser/
# doko* — npm install -g @dokobot/cli 可恢复
skills/doko*

# ── 混合目录：忽略内置，保留用户自建（zenmux-video） ──────────────────────────
skills/creative/DESCRIPTION.md
skills/creative/architecture-diagram/
skills/creative/ascii-art/
skills/creative/ascii-video/
skills/creative/baoyu-comic/
skills/creative/baoyu-infographic/
skills/creative/claude-design/
skills/creative/comfyui/
skills/creative/creative-ideation/
skills/creative/design-md/
skills/creative/excalidraw/
skills/creative/humanizer/
skills/creative/manim-video/
skills/creative/p5js/
skills/creative/pixel-art/
skills/creative/popular-web-designs/
skills/creative/pretext/
skills/creative/sketch/
skills/creative/songwriting-and-ai-music/
skills/creative/touchdesigner-mcp/

# ── 用户自建 Skill 目录（全部追踪） ───────────────────────────────────────────
# skills/custom/ 下的所有内容自动纳入 Git 管理
# 当前清单：hermes-weekly-cleanup, nomad-imessage, role-canada-affairs,
#   role-content-ops, role-investment-advisor, role-parenting-expert,
#   role-tech-advisor, tool-selection-strategy

# ── 独立仓库（已分流至独立 GitHub 仓库） ──────────────────────────────────────
skills/custom/image2webp-skill/
skills/custom/nomad-imessage/

# ── 浏览器调试 ──────────────────────────────────────────────────────────────
chrome-debug/

# ── 生成的媒体文件 ──────────────────────────────────────────────────────────
images/

# ── Curator 自动备份 / 归档（非用户创作） ─────────────────────────────────────
skills/.archive/
skills/.curator_backups/

# ── macOS 系统文件 ──────────────────────────────────────────────────────────
.DS_Store

# ── 备份 / 历史 / 第三方工具配置 ─────────────────────────────────────────────
lsp/
backups/
.hermes_history
.claude/
.vscode/
test.env