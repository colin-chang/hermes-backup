# Hermes Agent — ~/.hermes/ dotfile gitignore
# 策略：追踪自定义配置和用户创作，忽略运行时/缓存/二进制/凭证

# 代码本体（自带 Git）
hermes-agent/
hermes-webui/
plugins/

# 敏感凭证
.env
auth.json

# 运行时状态
*.lock
*.pid
.clean_shutdown
processes.json
.update_check
.update_exit_code
.install_method

# 运行时空目录
pairing/
hooks/

# 数据库（SQLite + WAL）
state.db*
kanban.db*
sessions.db
sessions/

# 日志 & 缓存
logs/
cache/
audio_cache/
image_cache/
sandboxes/
*cache.yaml
*cache.json
*snapshot.json
state-snapshots/

# Gateway
gateway/
gateway*
channel_directory.json
discord_threads.json

# WebUI
webui/
webui.*

# 定时任务输出
cron/output/

# 二进制
bin/

# Desktop 安装产物
node/
bootstrap-cache/
hermes-setup
desktop-build-stamp.json

# Agent 生成的临时工作产物

# Skills — 忽略全部，仅保留 custom/
skills/
!skills/custom/
# 独立仓库
skills/custom/image2webp-skill/
skills/custom/nomad-imessage/

# 浏览器调试
chrome-debug/

# 生成的媒体
images/

# macOS
.DS_Store

# 备份 & 第三方工具
lsp/
backups/
.hermes_history
.claude/
.vscode/
test.env
